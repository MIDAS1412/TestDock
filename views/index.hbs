<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/home.css">
</head>
<body>
  <main class="hero-shell">
    <section class="hero-card">
      <p class="eyebrow">GitHub Actions Deployment</p>
      <h1>{{title}}</h1>
      <p class="headline">{{headline}}</p>
      <p class="description">{{description}}</p>

      <div class="action-row">
        <a class="button primary" href="{{primaryAction}}">Open Inventory API</a>
        <a class="button secondary" href="{{secondaryAction}}">Check Health</a>
      </div>

      <dl class="stats-grid">
        <div class="stat-item">
          <dt>Container Port</dt>
          <dd>{{containerPort}}</dd>
        </div>
        <div class="stat-item">
          <dt>Deploy Flow</dt>
          <dd>Docker Hub + Webhook</dd>
        </div>
        <div class="stat-item">
          <dt>Deploy Slot</dt>
          <dd>{{deploySlot}}</dd>
        </div>
      </dl>
    </section>
  </main>
</body>
</html>
